rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid &&
               data.email is string && data.email.size() <= 256 &&
               data.createdAt is timestamp;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // Saved Contacts Rules
    match /users/{userId}/saved_contacts/{contactId} {
      function isValidContact(data) {
        return data.userId == request.auth.uid &&
               data.type is string && data.type.size() <= 50 &&
               data.value is string && data.value.size() <= 256 &&
               data.savedAt is timestamp;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidContact(request.resource.data) && isValidId(contactId);
      allow delete: if isOwner(userId);
    }

    // Search History Rules
    match /users/{userId}/search_history/{historyId} {
      function isValidHistory(data) {
        return data.userId == request.auth.uid &&
               data.query is string && data.query.size() <= 512 &&
               data.timestamp is timestamp;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidHistory(request.resource.data) && isValidId(historyId);
      allow delete: if isOwner(userId);
    }
  }
}
