{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile and private data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Contact": {
      "title": "Saved Contact",
      "description": "Business contact saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "type": "string" },
        "confidence": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "verificationStatus": { "type": "string" },
        "userId": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "value", "userId", "savedAt"]
    },
    "SearchHistory": {
      "title": "History Item",
      "description": "Past searches conducted by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "result": { "type": "object" }
      },
      "required": ["id", "userId", "query", "timestamp", "result"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user collection"
    },
    "/users/{userId}/saved_contacts/{contactId}": {
      "schema": "Contact",
      "description": "User's bookmarked business leads"
    },
    "/users/{userId}/search_history/{historyId}": {
      "schema": "SearchHistory",
      "description": "Log of user's past discovery searches"
    }
  }
}
